modules = ["nodejs-24", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/medical-app-mobile: MedStudent Mobile"

[[workflows.workflow]]
name = "artifacts/medical-app-mobile: MedStudent Mobile"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/medical-app-mobile run dev"
waitForPort = 8099

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 90000

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 5000

[[ports]]
localPort = 8083
externalPort = 5173

[[ports]]
localPort = 8084
externalPort = 6000

[[ports]]
localPort = 8085
externalPort = 6800

[[ports]]
localPort = 8086
externalPort = 8000

[[ports]]
localPort = 8099
externalPort = 8099

[[ports]]
localPort = 8100
externalPort = 4200

[[ports]]
localPort = 20087
externalPort = 3000
